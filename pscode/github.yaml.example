# pscode GitHub Projects integration config
# Copy this file to pscode/github.yaml and fill in your project's values.
# Run /ps:github-setup to configure this file interactively.

# GitHub repository in owner/repo format
repo: owner/my-project

# GitHub Projects (V2) project number (visible in the project URL)
project: 1

# Project GraphQL node ID — auto-discovered by /ps:github-setup
# To find manually: gh api graphql -f query='query($o:String!,$n:Int!){user(login:$o){projectV2(number:$n){id}}}' -F o=owner -F n=1
projectNodeId: PVT_xxxxxxxxxxxx

# Status field ID — auto-discovered by /ps:github-setup
# To find manually: gh project field-list 1 --owner owner --format json
statusFieldId: PVTSSF_xxxxxxxxxxxx

# Path to the gh CLI binary (default: "gh", which assumes it's in PATH)
# Override for non-standard installations, e.g. on Windows:
# gh: /mnt/c/Program Files/GitHub CLI/gh.exe
gh: gh

# Mapping of Pscode workflow stages to GitHub Projects status option IDs.
# Auto-discovered by /ps:github-setup; to find manually inspect the field-list output.
statuses:
  backlog:     xxxxxxxx   # "Backlog" or equivalent
  proposed:    xxxxxxxx   # "In Refinement" or equivalent (optional)
  accepted:    xxxxxxxx   # "Ready" or "Accepted" or equivalent
  in_progress: xxxxxxxx   # "In Progress" or equivalent
  in_review:   xxxxxxxx   # "In Review" (code review) — optional
  done:        xxxxxxxx   # "Done" or "Completed" or equivalent
  archived:    xxxxxxxx   # "Archived" — optional

# Issue number extraction pattern.
# Pscode extracts the issue number from the change name using this prefix.
# Default "issue" matches "issue-42-my-feature" → issue #42.
# Change to match your naming convention, e.g. "task" for "task-7-login".
# Set to "none" to disable automatic extraction.
issuePattern: issue

# Manual overrides: map change names directly to issue numbers.
# Use this when your change name doesn't follow the issuePattern convention.
# links:
#   my-change-name: 42
#   another-change: 7

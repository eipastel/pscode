{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/arch-guard.mjs"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/jira-context.mjs"
          }
        ]
      }
    ]
  }
}